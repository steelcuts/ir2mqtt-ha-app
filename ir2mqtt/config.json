{
  "name": "IR2MQTT",
  "version": "1.0.0-beta.2",
  "slug": "ir2mqtt",
  "description": "Web UI for IR Bridges with Learning and MQTT Auto-Discovery",
  "url": "https://github.com/steelcuts/ir2mqtt",
  "image": "ghcr.io/steelcuts/ir2mqtt-ha-app",
  "arch": [
    "aarch64",
    "amd64",
    "armv7"
  ],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:remote",
  "panel_title": "IR2MQTT",
  "uart": true,
  "udev": true,
  "options": {
    "mqtt_broker": "core-mosquitto",
    "mqtt_port": 1883,
    "mqtt_user": "",
    "mqtt_pass": ""
  },
  "schema": {
    "mqtt_broker": "str",
    "mqtt_port": "int",
    "mqtt_user": "str",
    "mqtt_pass": "password"
  }
}
